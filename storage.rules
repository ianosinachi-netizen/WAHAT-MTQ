rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      
      // Anyone can view images
      allow read: if true;

      // Only YOU can upload
      allow write: if request.auth != null 
                   && request.auth.token.email == "ianosinachi@gmail.com";
    }
  }
}
